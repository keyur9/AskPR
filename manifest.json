{
  "manifest_version": 3,
  "name": "AskPR",
  "version": "0.1.0",
  "description": "Ask the PR. Talk to any GitHub pull request as if talking to the engineer who wrote it.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*"
  ],

  "background": {
    "service_worker": "src/background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://github.com/*/pull/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
